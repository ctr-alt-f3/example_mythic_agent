#include <stdbool.h>
#include <stdio.h>
#include <stdlib.h>


#define MAX_SIZE 100
typedef struct {
int items[MAX_SIZE];
unsigned int front;
unsigned int rear;
short size;
} Queue;

void init_queue(Queue *q){
q->rear = 0;
q->front = 0;
q->size = 0;	
}

static inline bool isEmpty(Queue *q) {
    return q->size == 0;
}

static inline bool isFull(Queue *q) {
    return q->size==MAX_SIZE;
}

void enqueue(Queue *q, int val){
	if(isFull(q)){
		printf("queue full :(\n");
		return;
	}	
	q->items[q->rear] = val;
	q->rear = (q->rear+1)%MAX_SIZE;
	q->size++;
	return;
}

int dequeue(Queue *q){
	if(isEmpty(q)){
		printf("queue empty :(\n");
		return 0;
	}
	int ret = q->items[q->front];
	q->front = (q->front + 1) %MAX_SIZE;
	q->size--;
	return ret;
}
void del_task(Queue *q){
	if(isEmpty(q)){
		printf("queue empty :(\n");
		return;
	}
	q->front = (q->front + 1) %MAX_SIZE;
	q->size--;
}

int peek(Queue *q){
if(isEmpty(q)){
		printf("queue empty :(\n");
		return 0;
	}

return q->items[q->front];
}
